# ============================================================
# RedOS HBX Data Extraction Tool — Environment Variables
# Copy this to .env.local for local dev
# Set these as Vercel Environment Variables for production
# ============================================================

# ─── Auth ────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# ─── User Accounts (JSON array of {email, password, name, role}) ──
# Generate password hash: node -e "const b=require('bcryptjs');console.log(b.hashSync('yourpass',10))"
USERS_JSON=[{"email":"admin@redhealth.in","passwordHash":"$2a$10$...","name":"Admin","role":"admin"},{"email":"ops@redhealth.in","passwordHash":"$2a$10$...","name":"Ops User","role":"ops"},{"email":"finance@redhealth.in","passwordHash":"$2a$10$...","name":"Finance User","role":"finance"}]

# ─── BigQuery (RedOS) ────────────────────────────────────────
# Option A: Service Account JSON (base64 encoded)
BIGQUERY_CREDENTIALS_BASE64=base64_encoded_service_account_json

# Option B: Individual fields
BIGQUERY_PROJECT_ID=redos-prod
BIGQUERY_DATASET=rdp
BIGQUERY_CLIENT_EMAIL=your-sa@redos-prod.iam.gserviceaccount.com
BIGQUERY_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Snowflake (HBX) ────────────────────────────────────────
SNOWFLAKE_ACCOUNT=your-account.snowflakecomputing.com
SNOWFLAKE_USERNAME=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_DATABASE=BLADE
SNOWFLAKE_SCHEMA=CORE
SNOWFLAKE_WAREHOUSE=your_warehouse
SNOWFLAKE_ROLE=your_role

# ─── Anthropic (AI NL Parser) ───────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── App Config ─────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Red Health Data Hub
MAX_ROWS=50000
QUERY_TIMEOUT_MS=120000
